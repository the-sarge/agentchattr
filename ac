#!/usr/bin/env sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if ! command -v go >/dev/null 2>&1; then
    cat >&2 <<'EOF'
agentchattr ac requires Go.

Install Go, then retry:
  https://go.dev/doc/install

Python fallback:
  ./ac-python ...
EOF
    exit 1
fi

cd "$ROOT"
exec go run ./cmd/ac "$@"
